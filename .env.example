# --- Required ---
OPENAI_API_KEY=
TELEGRAM_BOT_TOKEN=

# --- Optional but recommended ---
LLM_MODEL=gpt-4o
HF_TOKEN=
LOCAL_HF_MODEL_ENABLED=false

# --- Setu Account Aggregator (optional; mock data is used if blank) ---
# Sandbox base URL: uat.setu.co. Production: prod.setu.co.
SETU_BASE_URL=https://uat.setu.co
# OAuth keys from Bridge → Org settings → API keys (NOT the product-specific
# x-client-id/x-client-secret pair shown on the product page).
SETU_CLIENT_ID=
SETU_CLIENT_SECRET=
# Product ID from the AA product page on Bridge.
SETU_PRODUCT_INSTANCE_ID=
SETU_REDIRECT_URL=https://example.com/callback
SETU_WEBHOOK_SECRET=

# --- Storage (defaults to data/finehance.db) ---
# FINEHANCE_DB_PATH=
